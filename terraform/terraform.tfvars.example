# Example Terraform variables file for OptimACS deployment on Proxmox
# Copy this file to terraform.tfvars and customize the values

# =============================================================================
# REQUIRED: Proxmox Connection
# =============================================================================

# Proxmox API endpoint
proxmox_api_url = "https://your-proxmox-host:8006/api2/json"

# Proxmox credentials
proxmox_user     = "root@pam"
proxmox_password = "your-proxmox-password"

# Skip TLS verification (set to false in production with valid certs)
proxmox_tls_insecure = true

# =============================================================================
# Proxmox Node Settings
# =============================================================================

# Target Proxmox node
proxmox_node = "pve"

# Storage pool for VM disk
proxmox_storage = "local-lvm"

# Network bridge
proxmox_bridge = "vmbr0"

# VM template to clone (must be cloud-init enabled)
proxmox_template = "debian-12-cloudinit"

# =============================================================================
# VM Configuration
# =============================================================================

# Set to false to use an existing VM instead of creating a new one
provision_vm = true

# VM name (when creating new VM)
vm_name = "optimacs-server"

# VM specifications
vm_cores     = 4      # 4 CPU cores
vm_memory    = 8192   # 8 GB RAM
vm_disk_size = "50G"  # 50 GB disk

# Static IP configuration (optional - leave empty for DHCP)
# Format: ip=192.168.1.100/24,gw=192.168.1.1
vm_ipconfig = ""

# =============================================================================
# SSH Configuration
# =============================================================================

# Only needed if provision_vm = false
vm_host = ""

# SSH credentials
ssh_user             = "debian"
ssh_private_key_path = "~/.ssh/id_rsa"
ssh_public_key_path  = "~/.ssh/id_rsa.pub"
ssh_port             = 22

# Password auth (alternative to keys, not recommended)
# ssh_password = ""

# =============================================================================
# OptimACS Application Settings
# =============================================================================

# Path to your .env file
env_file_path = "../.env"

# step-ca CA password (must be secure!)
stepca_password = "your-secure-ca-password-change-me"

# step-ca JWK provisioner name (used as JWT issuer claim)
# This must match the provisioner name configured in step-ca
stepca_provisioner_name = "acserver@optimacs.local"

# Path to step-ca provisioner private key (PKCS#8 PEM format)
# Extract this from step-ca after initialization using:
#   docker compose exec step-ca step ca provisioner list
#   docker compose exec step-ca cat /home/step/.step/config/ca.json
# Then decrypt and convert to PKCS#8 PEM format
# Leave empty to skip automatic provisioner key deployment
stepca_provisioner_key_path = ""

# Initial admin account (optional but recommended)
admin_username = "admin"
admin_password = "your-secure-admin-password"

# Application version
optimacs_version = "latest"
