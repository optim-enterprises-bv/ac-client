# ── Stage 1: Build ac-client ─────────────────────────────────────────────────
FROM rustlang/rust:nightly-slim AS builder

# Install protobuf compiler for prost-build
RUN apt-get update && apt-get install -y protobuf-compiler && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Cache dependency downloads before copying full source
COPY Cargo.toml Cargo.lock ./
RUN mkdir -p src && echo 'fn main(){}' > src/main.rs

# Pull all crates (build will fail on link but layer is cached)
RUN cargo fetch

# Copy full source and build for release
COPY . .
RUN cargo build --release 2>&1

# ── Stage 2: Runtime ─────────────────────────────────────────────────────────
FROM rustlang/rust:nightly-slim AS runtime

# Install openssl for dev cert generation and basic networking tools
RUN apt-get update && apt-get install -y openssl iproute2 ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/ac-client /usr/bin/ac-client

COPY docker/openwrt-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Config and cert directories (mirrors OpenWrt /etc/apclient layout)
RUN mkdir -p /etc/apclient/init /tmp/firmware /tmp/cam /var/run

ENTRYPOINT ["/entrypoint.sh"]
